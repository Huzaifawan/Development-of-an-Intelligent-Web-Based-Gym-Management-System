# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
# Local:  mongodb://localhost:27017/gym_management
# Atlas:  mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gym_management
MONGO_URI=mongodb://localhost:27017/gym_management

# ─── JWT ──────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one at: https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────
# Your frontend URL (React app)
CLIENT_URL=http://localhost:3000
